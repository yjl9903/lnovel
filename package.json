{
  "name": "@lnovel/monorepo",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write '**/*.{ts,tsx,js,mjs}'",
    "lnovel": "tsx packages/lnovel/src/cli.ts",
    "release": "bumpp package.json apps/*/package.json packages/*/package.json --commit --push --tag && pnpm -r publish --access public",
    "server:dev": "tsx apps/server/src/cli.ts",
    "server:start": "node apps/server/cli.mjs",
    "test:ci": "turbo run test:ci",
    "typecheck": "turbo run typecheck",
    "preversion": "turbo run test:ci",
    "postversion": "turbo run build"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.3",
    "bumpp": "latest",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.7",
    "tsx": "^4.23.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=v24.0.0"
  }
}
