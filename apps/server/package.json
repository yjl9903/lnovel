{
  "name": "@lnovel/server",
  "version": "0.0.4",
  "private": true,
  "description": "lnovel api server",
  "keywords": [
    "light-novels"
  ],
  "homepage": "https://github.com/yjl9903/lnovel#readme",
  "bugs": {
    "url": "https://github.com/yjl9903/lnovel/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yjl9903/lnovel.git"
  },
  "license": "AGPL-3.0",
  "author": "XLor",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "lnovel-server": "./cli.mjs"
  },
  "files": [
    "*.mjs",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "browser:prepare": "cloakbrowser install",
    "drizzle": "drizzle-kit",
    "drizzle:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "2.0.4",
    "@hono/zod-validator": "0.8.0",
    "bilinovel": "workspace:*",
    "breadc": "1.0.0-beta.15",
    "cloakbrowser": "0.3.31",
    "consola": "3.4.2",
    "croner": "10.0.1",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "drizzle-sqlite": "^0.0.1",
    "feed": "5.2.1",
    "flomise": "0.0.6",
    "hono": "4.12.23",
    "lnovel": "workspace:*",
    "lru-cache": "11.5.0",
    "playwright-core": "1.60.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "drizzle-kit": "0.31.10"
  },
  "engines": {
    "node": ">=v24.0.0"
  }
}
